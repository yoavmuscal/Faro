# Google Gemini (required for agent steps)
GEMINI_API_KEY=

# MongoDB
MONGODB_URI=
MONGODB_DB=faro

# ElevenLabs — enables voice summary (MP3 stored in MongoDB, URL /audio/{session_id})
ELEVENLABS_API_KEY=
# Optional overrides (defaults: Rachel voice, eleven_multilingual_v2)
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=
# ELEVENLABS_MAX_CHARS=4000   # TTS only; full summary text is still stored unchanged
